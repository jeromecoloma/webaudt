#compdef webaudt
# zsh completion for webaudt
# Install: place this file as `_webaudt` somewhere on $fpath, e.g.
#   mkdir -p ~/.zsh/completions
#   ln -s /path/to/webaudt/completions/_webaudt ~/.zsh/completions/_webaudt
#   # Add to ~/.zshrc (before `compinit`):
#   fpath=(~/.zsh/completions $fpath)
#   autoload -Uz compinit && compinit

_webaudt_sites() {
    local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/webaudt/config.toml"
    [[ -f "$cfg" ]] || return
    (( $+commands[yq] )) || return
    local -a names
    names=(${(f)"$(yq -p toml -o json '.' "$cfg" 2>/dev/null | jq -r '(.sites // [])[].name' 2>/dev/null)"})
    _describe 'site' names
}

_webaudt() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '1: :->subcmd' \
        '*:: :->args'

    case $state in
        subcmd)
            local -a subs=(
                'add:Register a new site'
                'rm:Remove a registered site'
                'remove:Remove a registered site'
                'list:List registered sites'
                'ls:List registered sites'
                'refresh:Re-run audits'
                'status:Print audit summary'
                'doctor:Check dependencies'
                'help:Show help'
                '--help:Show help'
                '--version:Show version'
            )
            _describe 'subcommand' subs
            ;;
        args)
            case $words[1] in
                add)
                    _arguments \
                        '--name[Override display name]:name:' \
                        '--type[Ecosystem type]:type:(composer npm both)' \
                        '--composer-path[Explicit composer audit path]:dir:_files -/' \
                        '--npm-path[Explicit npm audit path]:dir:_files -/' \
                        '--composer-bin[Override composer binary for this site]:file:_files' \
                        '--npm-bin[Override npm binary for this site]:file:_files' \
                        '*:site path:_files -/'
                    ;;
                rm|remove)
                    _webaudt_sites
                    ;;
                refresh)
                    _arguments \
                        '--all[Force-refresh every site, ignore TTL]' \
                        '*:site:->sites'
                    [[ $state == sites ]] && _webaudt_sites
                    ;;
                status)
                    _arguments \
                        '--json[Emit JSON instead of plain text]' \
                        '*:site:->sites'
                    [[ $state == sites ]] && _webaudt_sites
                    ;;
            esac
            ;;
    esac
}

_webaudt "$@"
