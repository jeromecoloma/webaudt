#!/usr/bin/env bash
# webaudt — TUI for composer/npm audit across registered local sites.

set -euo pipefail
IFS=$'\n\t'

# Resolve the install root (follow symlinks).
__webaudt_resolve_root() {
    local src="${BASH_SOURCE[0]}" dir
    while [[ -L "$src" ]]; do
        dir=$(cd -P "$(dirname "$src")" && pwd)
        src=$(readlink "$src")
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    cd -P "$(dirname "$src")/.." && pwd
}

WEBAUDT_ROOT="$(__webaudt_resolve_root)"
WEBAUDT_LIB="$WEBAUDT_ROOT/lib"

# shellcheck source=../lib/common.sh
source "$WEBAUDT_LIB/common.sh"
# shellcheck source=../lib/config.sh
source "$WEBAUDT_LIB/config.sh"
# shellcheck source=../lib/cache.sh
source "$WEBAUDT_LIB/cache.sh"
# shellcheck source=../lib/audit.sh
source "$WEBAUDT_LIB/audit.sh"
# shellcheck source=../lib/registry.sh
source "$WEBAUDT_LIB/registry.sh"
# shellcheck source=../lib/preview.sh
source "$WEBAUDT_LIB/preview.sh"
# shellcheck source=../lib/ui.sh
source "$WEBAUDT_LIB/ui.sh"
# shellcheck source=../lib/doctor.sh
source "$WEBAUDT_LIB/doctor.sh"

usage() {
    common_banner
    cat <<EOF

Usage:
  webaudt                       Open TUI
  webaudt add <path> [opts]     Register a site
  webaudt rm <name>             Remove a site (alias: remove)
  webaudt list                  List sites (alias: ls)
  webaudt refresh [names...]    Re-run audits
  webaudt status [name] [--json] Print audit summary
  webaudt doctor                Check dependencies
  webaudt --help                Show this help
  webaudt --version             Show version

Options for 'add':
  --name <s>             Override display name
  --type <t>             composer | npm | both
  --composer-path <dir>  Explicit composer audit path
  --npm-path <dir>       Explicit npm audit path
  --composer-bin <path>  Override the composer binary for this site
  --npm-bin <path>       Override the npm binary for this site

Options for 'refresh':
  --all                  Force-refresh every site (ignore TTL)

Options for 'status':
  --json                 Emit JSON instead of plain text
EOF
}

main() {
    common_ensure_dirs

    local cmd="${1:-__tui__}"
    [[ $# -gt 0 ]] && shift || true

    case "$cmd" in
        __tui__)        ui_open ;;
        add)            registry_add "$@" ;;
        rm|remove)      registry_rm "$@" ;;
        list|ls)        registry_list "$@" ;;
        refresh)        audit_refresh "$@" ;;
        status)         audit_status "$@" ;;
        doctor)         doctor_run "$@" ;;
        _list)          ui_emit_list "$@" ;;
        _preview)       preview_render "$@" ;;
        _refresh_one)   audit_refresh_one "$@" ;;
        _details)       preview_details "$@" ;;
        --help|-h|help) usage ;;
        --version|-V)   printf 'webaudt %s\n' "$WEBAUDT_VERSION" ;;
        *)
            printf 'webaudt: unknown command: %s\n\n' "$cmd" >&2
            usage >&2
            exit 2
            ;;
    esac
}

main "$@"
